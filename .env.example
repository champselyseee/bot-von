# ─── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ─── VPN management API (vpn-api.py на сервере) ──────────────────────────────
VPN_API_URL=http://YOUR_SERVER_IP:8765
VPN_API_KEY=your_vpn_api_key_here

# ─── VPN server ──────────────────────────────────────────────────────────────
VPN_DOMAIN=your_vpn_domain_here
VPN_SUB_PORT=2097

# ─── YooKassa (бизнес-аккаунт на yookassa.ru) ────────────────────────────────
# Webhook URL для настройки в ЛК: https://<RAILWAY_DOMAIN>/payment/webhook
YOOMONEY_SHOP_ID=
YOOMONEY_SECRET_KEY=

# ─── Цены (₽) ────────────────────────────────────────────────────────────────
PRICE_2W=149
PRICE_1M=249

# ─── База данных ─────────────────────────────────────────────────────────────
# На Railway: создай Volume, примонтируй к /data
DB_PATH=/data/bot.db

# ─── Администраторы ──────────────────────────────────────────────────────────
# Telegram user ID через запятую. Узнать: @userinfobot
ADMIN_IDS=

# ─── Railway выставляет автоматически ────────────────────────────────────────
# PORT=8080
# RAILWAY_PUBLIC_DOMAIN=xxx.up.railway.app
